# Discord Webhook URL - paste the full URL from your Discord channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Polling interval in milliseconds (default: 5000 = 5 seconds)
POLL_INTERVAL_MS=5000

# Note: The Oref API is geo-restricted to Israeli IPs.
# If your server is outside Israel you will receive 403 responses.
# Run the bot on a server/VPS hosted in Israel to receive live alerts.
