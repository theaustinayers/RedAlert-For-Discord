# Discord Webhook URL - paste the full URL from your Discord channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Polling interval in milliseconds (default: 5000 = 5 seconds)
POLL_INTERVAL_MS=5000

# (Optional) Override the built-in Israeli proxy list with a single proxy.
# If not set, the bot rotates through its built-in Israeli proxy pool automatically.
# Format: http://host:port  (HTTP proxies only)
# PROXY_URL=http://51.85.49.118:9482
