# Discord Webhook URL - paste the full URL from your Discord channel settings
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Polling interval in milliseconds (default: 5000 = 5 seconds)
POLL_INTERVAL_MS=5000

# (Optional) Override the built-in Israeli proxy pool with a single specific proxy.
# If not set, the bot automatically rotates through its built-in pool of verified
# Israeli proxies. All proxies below were verified working on 2026-03-13.
# Format: http://host:port
#
# Sample working proxies (51.85.49.118 = Amazon AWS Tel Aviv):
# PROXY_URL=http://51.85.49.118:8053
# PROXY_URL=http://51.85.49.118:39220
# PROXY_URL=http://51.85.49.118:176
# PROXY_URL=http://51.85.49.118:2887
# PROXY_URL=http://51.85.49.118:6116
# PROXY_URL=http://51.85.49.118:50918
# PROXY_URL=http://51.85.49.118:8050
# PROXY_URL=http://51.85.49.118:1521
# PROXY_URL=http://51.85.49.118:22901
